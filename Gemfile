source "https://rubygems.org"

# GitHub Pages builds this site natively, so this Gemfile is only for running it
# locally (`bundle exec jekyll serve`). Only plugins on the GitHub Pages
# whitelist may be used, or the published build will silently skip them.
gem "jekyll", "~> 4.4"

group :jekyll_plugins do
  gem "jekyll-sitemap", "~> 1.4"
end
